# Discord Developer Portal > Bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# เซิร์ฟเวอร์ที่จะใช้งาน (จำเป็น เพื่อให้ลงทะเบียน /setup ได้ทันที)
DISCORD_GUILD_ID=

# Supabase > Connect > Session pooler (port 5432)
# ใช้ URL เดียวสำหรับทั้งตัวบอทและ Prisma migrations
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres?sslmode=require"

# ค่าเหล่านี้ไม่จำเป็น: /setup จะสร้าง resource และบันทึก ID ลง Supabase
# หากกรอกไว้ บอทจะใช้ resource เดิมก่อน
REGISTRATION_CHANNEL_ID=
ADMIN_CHANNEL_ID=
INTERVIEW_CHANNEL_ID=
INTERVIEW_ROLE_ID=
MEMBER_ROLE_ID=
ADMIN_ROLE_ID=

# Render sets PORT automatically. This value is only a local fallback.
PORT=3000
