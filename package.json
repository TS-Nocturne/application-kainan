{
  "name": "kainan-high-verify-bot",
  "version": "1.0.0",
  "description": "Discord registration and verification bot for KAINAN HIGH",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "prisma": "^7.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
